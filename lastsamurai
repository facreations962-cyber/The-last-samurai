<script>
// ── AUDIO ENGINE ──────────────────────────────
const bgm      = document.getElementById('bgm');
const sfxSword = document.getElementById('sfxSword');
const sfxBoom  = document.getElementById('sfxBoom');
const sfxWhoosh= document.getElementById('sfxWhoosh');
let soundOn    = false;
let bgmStarted = false;

bgm.volume = 0.22;
sfxSword.volume = 0.55;
sfxBoom.volume  = 0.5;
sfxWhoosh.volume= 0.4;

function startBGM(){
  if(bgmStarted || !soundOn) return;
  bgm.play().then(()=>{ bgmStarted=true; }).catch(()=>{});
}

function playFx(el){
  if(!soundOn) return;
  const type = el.dataset.sound;
  if(!type) return;
  let audio;
  if(type==='sword')  audio=sfxSword;
  if(type==='boom')   audio=sfxBoom;
  if(type==='whoosh') audio=sfxWhoosh;
  if(!audio) return;
  audio.currentTime=0;
  audio.play().catch(()=>{});
}

function toggleSound(){
  soundOn = !soundOn;
  const btn = document.getElementById('snd');
  if(soundOn){
    btn.textContent='🔊';
    btn.style.opacity='1';
    startBGM();
    if(bgmStarted) bgm.play().catch(()=>{});
  } else {
    btn.textContent='🔇';
    btn.style.opacity='0.5';
    bgm.pause();
  }
}

function startReading(){
  soundOn = true;
  document.getElementById('snd').textContent='🔊';
  document.getElementById('snd').style.opacity='1';
  document.getElementById('story').scrollIntoView({behavior:'smooth'});
  setTimeout(()=>startBGM(), 600);
}

// ── LOADER ────────────────────────────────────
window.addEventListener('load',()=>{
  setTimeout(()=> document.getElementById('loader').classList.add('out'), 3000);
});

// ── PROGRESS ──────────────────────────────────
function updateProg(){
  const s=window.scrollY, h=document.documentElement.scrollHeight-window.innerHeight;
  document.getElementById('prog').style.width=(s/h*100)+'%';
}

// ── CHAPTER NAV ───────────────────────────────
const TITLES=['','The Fog That Should Not Exist','The Power That Has No Name Yet',
  'The White That Does Not Burn','The Boy Who Sealed Himself Shut',
  'Goodbye','The Weight of a Mission','The Last Samurai'];

function updateNav(){
  const nav=document.getElementById('cnav');
  const txt=document.getElementById('cnavt');
  if(window.scrollY < document.getElementById('hero').offsetHeight*0.4){
    nav.classList.remove('show'); return;
  }
  nav.classList.add('show');
  const mid=window.scrollY+window.innerHeight/2;
  document.querySelectorAll('.chap').forEach(c=>{
    if(mid>=c.offsetTop && mid<c.offsetTop+c.offsetHeight)
      txt.textContent='Ch.'+c.dataset.ch+' — '+TITLES[+c.dataset.ch];
  });
}

// ── SCROLL REVEAL + SOUND TRIGGERS ────────────
const beatObs = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting && !e.target.classList.contains('on')){
      e.target.classList.add('on');
      playFx(e.target);
    }
  });
},{threshold:0.15, rootMargin:'0px 0px -40px 0px'});

document.querySelectorAll('.beat').forEach(b=> beatObs.observe(b));

// ── END REVEAL ────────────────────────────────
const endObs = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.ek,.et,.es').forEach(el=>el.classList.add('on'));
    }
  });
},{threshold:0.3});
endObs.observe(document.getElementById('end'));

// ── PARALLAX HERO BG ──────────────────────────
window.addEventListener('scroll',()=>{
  const bg=document.querySelector('.hbg');
  if(bg) bg.style.transform=`translate(-50%,calc(-50% + ${window.scrollY*.28}px))`;
  updateProg();
  updateNav();
},{passive:true});
</script>
