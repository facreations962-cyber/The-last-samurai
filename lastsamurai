<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<section id="hero">
  <div class="hbg">最後の侍</div>
  <div class="hi">
    <div class="he">An Ancient Epic of Steel &amp; Spirits</div>
    <h1 class="ht">The Last<em>Samurai</em></h1>
    <div class="hline"></div>
    <p class="htag">
      "When the last light is taken from a man —<br>
      what remains is either ruin, or legend."
    </p>
